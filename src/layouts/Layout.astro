---
import { SEO } from 'astro-seo';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'People-first stories from London Grove Township, PA — documenting local government in a human way.' } = Astro.props;
const pageTitle = title === 'Home' ? 'London Grove Commons' : `${title} | London Grove Commons`;
---

<html lang="en" data-theme="londongrove">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/favicon-192.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700;800;900&display=swap" rel="stylesheet" />
    <link rel="alternate" type="application/rss+xml" title="London Grove Commons" href="/rss.xml" />
    <SEO
      title={pageTitle}
      description={description}
      openGraph={{
        basic: {
          title: pageTitle,
          type: 'website',
          image: '',
        },
      }}
    />
  </head>
  <body class="min-h-screen flex flex-col font-sans antialiased">
    <Navbar>
      <slot />
    </Navbar>
    <Footer />
  </body>
</html>
