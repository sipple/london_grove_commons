---
import Layout from '../layouts/Layout.astro';
import Landing from '../components/Landing.astro';
import { getCollection } from 'astro:content';

const stories = (await getCollection('stories', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout title="Home">
  <Landing />

  <section class="py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-sm font-medium text-base-content/40 uppercase tracking-wider mb-2">Latest</p>
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-primary mb-10">
        Latest Stories
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {stories.map(story => (
          <a href={`/stories/${story.id.replace(/\.md$/, '')}`} class="group block bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
            <div class="aspect-video overflow-hidden bg-base-300">
              {story.data.cover ? (
                <img
                  src={story.data.cover}
                  alt=""
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-primary to-secondary opacity-80"></div>
              )}
            </div>
            <div class="p-5">
              <h3 class="font-heading font-bold text-primary text-lg mb-1 group-hover:text-secondary transition-colors">
                {story.data.title}
              </h3>
              <p class="text-sm text-base-content/50 mb-2">
                {story.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
              <p class="text-sm text-base-content/70 line-clamp-2">{story.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
