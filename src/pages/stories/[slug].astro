---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const stories = await getCollection('stories', ({ data }) => !data.draft);
  return stories.map(story => ({
    params: { slug: story.id.replace(/\.md$/, '') },
    props: { story },
  }));
}

const { story } = Astro.props;
const { Content } = await render(story);
---

<Layout title={story.data.title} description={story.data.description}>
  <article class="max-w-3xl mx-auto px-4 py-16 bg-white rounded-xl shadow-sm my-8 sm:px-8">
    {story.data.cover && (
      <div class="aspect-video rounded-xl overflow-hidden mb-8">
        <img src={`${import.meta.env.BASE_URL}${story.data.cover.replace(/^\//, '')}`} alt="" class="w-full h-full object-cover" />
      </div>
    )}
    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-heading font-bold text-primary mb-4">{story.data.title}</h1>
      <div class="flex flex-wrap items-center gap-4 text-sm text-base-content/50">
        <time datetime={story.data.date.toISOString()}>
          {story.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <div class="flex gap-2">
          {story.data.tags.map(tag => (
            <span class="text-xs bg-base-200 px-2 py-1 rounded">{tag}</span>
          ))}
        </div>
      </div>
    </header>
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
    <div class="mt-12 pt-8 border-t border-base-300">
      <a href={`${import.meta.env.BASE_URL}stories`} class="text-sm text-secondary hover:text-primary transition-colors">&larr; Back to Stories</a>
    </div>
  </article>
</Layout>
