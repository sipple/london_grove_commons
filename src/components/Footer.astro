---
---

<footer class="mt-16">
  <div class="bg-base-300 py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid sm:grid-cols-3 gap-8">
        <div>
          <p class="font-heading font-bold text-primary mb-2">London Grove Commons</p>
          <p class="text-sm text-base-content/60 max-w-xs">
            A community resource bringing transparency and accessibility to local government in London Grove Township, Pennsylvania.
          </p>
        </div>
        <div>
          <p class="text-sm font-semibold text-base-content/80 mb-3">Quick Links</p>
          <ul class="space-y-2 text-sm">
            <li><a href="/" class="text-base-content/60 hover:text-primary transition-colors">Home</a></li>
            <li><a href="/stories" class="text-base-content/60 hover:text-primary transition-colors">Stories</a></li>
            <li><a href="/about" class="text-base-content/60 hover:text-primary transition-colors">About</a></li>
            <li><a href="/contact" class="text-base-content/60 hover:text-primary transition-colors">Contact</a></li>
            <li><a href="/rss.xml" class="text-base-content/60 hover:text-primary transition-colors">RSS Feed</a></li>
          </ul>
        </div>
        <div>
          <p class="text-sm font-semibold text-base-content/80 mb-3">Township Contact</p>
          <address class="not-italic text-sm text-base-content/60 space-y-1">
            <p>London Grove Township</p>
            <p>372 Rose Hill Road</p>
            <p>West Grove, PA 19390</p>
          </address>
          <a
            href="https://www.londongrove.org"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-secondary hover:text-primary transition-colors mt-3 inline-block"
          >
            Official Township Site &rarr;
          </a>
        </div>
      </div>
    </div>
  </div>
  <div class="bg-primary py-4">
    <div class="max-w-6xl mx-auto px-4 text-center text-xs text-primary-content/60">
      <p>&copy; {new Date().getFullYear()} London Grove Commons. Not an official township website.</p>
    </div>
  </div>
</footer>
