---
const navLinks = [
  { href: '/stories', label: 'Stories' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<div class="drawer">
  <input id="mobile-drawer" type="checkbox" class="drawer-toggle" />

  <div class="drawer-content flex flex-col">
    <header class="bg-primary">
      <nav class="navbar max-w-6xl mx-auto px-4">
        <div class="navbar-start">
          <label for="mobile-drawer" class="btn btn-ghost btn-square text-primary-content lg:hidden" aria-label="Open menu">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </label>
          <a href="/" class="flex items-center gap-2 ml-1 lg:ml-0">
            <span class="font-heading text-xl font-bold text-primary-content">London Grove Commons</span>
          </a>
        </div>
        <div class="navbar-end hidden lg:flex">
          <ul class="flex items-center gap-1">
            {navLinks.map(link => (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    "px-3 py-2 rounded-md text-sm font-medium transition-colors",
                    currentPath.startsWith(link.href)
                      ? "text-white bg-white/20"
                      : "text-primary-content/70 hover:text-white hover:bg-white/10"
                  ]}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>
  </div>

  <div class="drawer-side z-50">
    <label for="mobile-drawer" aria-label="Close menu" class="drawer-overlay"></label>
    <div class="bg-primary min-h-full w-72 p-6">
      <div class="mb-8">
        <a href="/" class="font-heading text-xl font-bold text-primary-content">London Grove Commons</a>
      </div>
      <ul class="space-y-1">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[
                "block px-3 py-2 rounded-md text-sm font-medium transition-colors",
                currentPath.startsWith(link.href)
                  ? "text-white bg-white/20"
                  : "text-primary-content/70 hover:text-white hover:bg-white/10"
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>
