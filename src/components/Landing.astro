<section class="py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <h1 class="text-4xl md:text-5xl font-heading font-bold text-primary leading-tight mb-6">
          London Grove Commons
        </h1>
        <p class="text-lg text-base-content/60 mb-2 font-medium">
          A modern, people-focused window into local government.
        </p>
        <p class="text-base text-base-content/50 mb-8 max-w-lg">
          We follow committees into their work, talk with the people who serve, and document local government in London Grove Township in a human way. All content and stories are independently produced.
        </p>
        <a href="/stories" class="btn btn-primary">
          Read Stories
        </a>
      </div>
      <div class="hidden lg:flex justify-center">
        <div class="relative w-80 h-80 rounded-2xl bg-primary flex items-center justify-center overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-secondary opacity-90"></div>
          <div class="relative text-center text-primary-content p-8">
            <svg class="w-20 h-20 mx-auto mb-4 opacity-90" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z"/>
            </svg>
            <span class="font-heading text-2xl font-bold block">LGC</span>
            <span class="text-sm opacity-70 mt-1 block">Est. 2026</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
